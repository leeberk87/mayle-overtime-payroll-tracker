{
  "name": "Organization",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "subscription_status": {
      "type": "string",
      "enum": [
        "trial",
        "active",
        "past_due",
        "canceled"
      ],
      "default": "trial"
    },
    "stripe_customer_id": {
      "type": "string"
    }
  },
  "required": [
    "name"
  ]
}